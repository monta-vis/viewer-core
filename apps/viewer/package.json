{
  "name": "@monta-vis/montavis-viewer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/index.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite --mode electron",
    "build": "tsc -b && vite build",
    "rebuild:native": "npx electron-rebuild --module-dir ../.. -o better-sqlite3",
    "clean:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\"",
    "build:mweb": "npm run build -w @monta-vis/mweb-viewer && node -e \"const fs=require('fs');fs.cpSync('../../packages/mweb-viewer/dist','dist-mweb',{recursive:true})\"",
    "build:electron": "npm run rebuild:native && npm run clean:electron && npm run build:mweb && vite build --mode electron && npm run protect && electron-builder",
    "build:electron:dir": "npm run rebuild:native && npm run clean:electron && npm run build:mweb && vite build --mode electron && npm run protect && electron-builder --dir",
    "protect": "node scripts/protect.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monta-vis/db-utils": "*",
    "@monta-vis/editor-core": "*",
    "@monta-vis/export-utils": "*",
    "@monta-vis/media-utils": "*",
    "@monta-vis/mweb-viewer": "*",
    "@monta-vis/viewer-core": "*",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.0.0",
    "bytenode": "^1.5.7",
    "electron-log": "^5.4.3",
    "electron-window-state": "^5.0.3",
    "extract-zip": "^2.0.1",
    "i18next": "^25.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^7.13.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/archiver": "^6.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/extract-zip": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "electronVersion": "35.7.5",
    "appId": "com.montavis.viewer",
    "productName": "Montavis Viewer",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist-mweb",
        "to": "dist-mweb",
        "filter": [
          "**/*"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "mvis",
        "name": "Montavis Instruction",
        "description": "Montavis Viewer Instruction File",
        "icon": "resources/mvis-file.ico",
        "role": "Viewer"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/icon.ico",
      "resources/mvis-file.ico",
      {
        "from": "../../node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../node_modules/bindings",
        "to": "node_modules/bindings",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../node_modules/file-uri-to-path",
        "to": "node_modules/file-uri-to-path",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../node_modules/bytenode",
        "to": "node_modules/bytenode",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
