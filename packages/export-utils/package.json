{
  "name": "@monta-vis/export-utils",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared pure export helpers for Montavis apps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./obfuscation": {
      "import": "./dist/obfuscation.js",
      "types": "./dist/obfuscation.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0",
    "yauzl": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/yauzl": "^2.10.3",
    "better-sqlite3": "^11.0.0",
    "yauzl": "^3.2.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "UNLICENSED"
}
